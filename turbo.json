{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "API_FOOTBALL_KEY",
    "NETWORK",
    "PARI_MATCH_FACTORY_ADDRESS",
    "STREAM_WALLET_FACTORY_ADDRESS",
    "CHILIZ_SWAP_ROUTER_ADDRESS",
    "LEADERBOARD_REWARDS_ADDRESS",
    "USDC_ADDRESS",
    "WCHZ_ADDRESS",
    "ADMIN_PRIVATE_KEY",
    "PRIVATE_KEY",
    "RPC_URL",
    "JWT_SECRET",
    "JWT_ISSUER",
    "JWT_EXPIRY",
    "PORT",
    "ALLOWED_ORIGINS",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "out/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:gen-types": {
      "cache": false,
      "outputs": ["src/infrastructure/persistence/types/database.types.ts"]
    }
  }
}
