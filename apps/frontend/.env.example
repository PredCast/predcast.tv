# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001

# Landing URL — used by middleware to redirect visitors without a valid access cookie.
# Defaults to http://localhost:3002 in dev, https://chiliztv.com in prod.
LANDING_URL=http://localhost:3002

# Dynamic Labs Configuration
NEXT_PUBLIC_STAGING_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

NEXT_PUBLIC_STAGING=

# Blockchain Configuration
PRIVATE_KEY=
RPC_URL=
NEXT_PUBLIC_URL=
NEXT_PUBLIC_NETWORK='testnet'

# ──────────────────────────────────────────────────────────────────────────
# Deployed contract addresses — Chiliz Spicy Testnet (chainId 88882)
# Source: apps/smart-contracts/chiliz-tv/deployments/chilizTestnet.json
# All addresses lowercased on purpose: viem rejects mixed-case non-EIP-55
# strings client-side, lowercase always parses safely.
#
# Mirror with `apps/backend/.env.example` — bump both files in lockstep
# when any deployed address changes (CLAUDE.md §7.11).
# ──────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_PARI_MATCH_FACTORY_ADDRESS=0xa7ce37924a9b7079960d2d10560f96cb4d233970
NEXT_PUBLIC_STREAM_WALLET_FACTORY_ADDRESS=0x739038ab34504763d188da5e11973b717e92e3b9
NEXT_PUBLIC_CHILIZ_SWAP_ROUTER_ADDRESS=0x44facf6a26789096d5f6bc1f6a5137979f304ef9
# LeaderboardRewards = ERC1967Proxy (NOT the implementation). Reads go to the proxy.
NEXT_PUBLIC_LEADERBOARD_REWARDS_ADDRESS=0xec696f28766f7673bdf39e4e4bd6002b22fe9e34

# Underlying tokens used by the swap router.
# USDC = the canonical "USD Coin" ERC20 on Spicy testnet that FanX/Kayen
# pairs liquidity against (verified via symbol() = "USDC", decimals = 6,
# WCHZ/USDC pair at 0xb93dc0d6e6d589b6bb4017bf7ebe69b47c9f4338).
NEXT_PUBLIC_USDC_ADDRESS=0x66f3ee96a0185216f8cb427d2bc4e53947cef60c
NEXT_PUBLIC_WCHZ_ADDRESS=0x678c34581db0a7808d0ac669d7025f1408c9a3c6

# Mainnet (Chiliz Chain 88888) — populate when deployed
NEXT_PUBLIC_PARI_MATCH_FACTORY_ADDRESS_MAINNET=
NEXT_PUBLIC_STREAM_WALLET_FACTORY_ADDRESS_MAINNET=
NEXT_PUBLIC_CHILIZ_SWAP_ROUTER_ADDRESS_MAINNET=
NEXT_PUBLIC_LEADERBOARD_REWARDS_ADDRESS_MAINNET=
NEXT_PUBLIC_USDC_ADDRESS_MAINNET=
NEXT_PUBLIC_WCHZ_ADDRESS_MAINNET=

