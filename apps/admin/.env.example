# Backend API base URL.
# Local: http://localhost:3001 — staging/prod: set in the Vercel project env.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Dynamic Labs environment ID — same value as apps/frontend (public client ID).
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# NOTE: ADMIN_GATE_CODE_HASH is a BACKEND variable (apps/backend/.env locally,
# Fly secret in staging/prod). The admin app never reads it — the gate code is
# verified server-side by POST /admin/gate.
