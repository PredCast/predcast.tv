{
  "name": "@chiliztv.com/backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsc && node dist/index.js",
    "dev": "nodemon --watch 'src/**/*.ts' --watch 'index.ts' --exec 'ts-node' index.ts",
    "dev:local": "dotenv -e .env.local -e .env -- pnpm dev",
    "dev:local:api": "PROCESS_ROLE=api dotenv -e .env.local -e .env -- pnpm dev",
    "dev:local:worker": "PROCESS_ROLE=worker PORT=3003 dotenv -e .env.local -e .env -- pnpm dev",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc --noEmit",
    "mediamtx": "mediamtx mediamtx.yml",
    "deploy:missing-contracts": "ts-node scripts/deploy-missing-betting-contracts.ts",
    "setup:markets": "ts-node scripts/setup-markets-for-existing-contracts.ts",
    "match:scenario": "ts-node src/presentation/cli/match-scenario.ts",
    "match:reset": "ts-node src/presentation/cli/match-reset.ts",
    "match:resolve": "ts-node src/presentation/cli/match-resolve.ts",
    "match:halftime": "ts-node src/presentation/cli/match-halftime.ts",
    "leaderboard:advance-epoch": "ts-node src/presentation/cli/leaderboard-advance-epoch.ts",
    "admin:grant": "ts-node src/presentation/cli/admin-grant.ts",
    "db:migrate": "ts-node scripts/run-migrations.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/helmet": "^0.0.48",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.33",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.15.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@chiliztv/blockchain": "workspace:*",
    "@chiliztv/domain": "workspace:*",
    "@chiliztv/shared": "workspace:*",
    "@supabase/supabase-js": "^2.52.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.15.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "rate-limit-redis": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "viem": "^2.31.7",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  }
}
