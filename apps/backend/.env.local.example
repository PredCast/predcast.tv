# Local development env for the backend. Copy to `.env.local` (gitignored).
# Defaults match `supabase start` and `compose.local.yml` Redis on this repo.

NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ──────────────────────────────────────────────────────────────────────────
# Supabase local — managed by `pnpm dev:supabase:start`. After the stack is
# up, run `pnpm dev:supabase:env` and paste the SUPABASE_URL / ANON_KEY /
# SERVICE_ROLE_KEY values it prints into this file. The CLI issues those
# keys based on the JWT signing key in `apps/backend/supabase/config.toml`.
# ──────────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Redis local — managed by `pnpm dev:redis:start` (compose.local.yml).
# Empty value drops the cache layer to NoopCacheService (single-instance,
# no warmup, no rate-limit-redis store); set to enable production-like DI.
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────
# Chiliz Spicy testnet (chainId 88882). Mirror of `.env.example` — bump
# both files in lockstep if the deployed addresses change (CLAUDE.md §10).
# ──────────────────────────────────────────────────────────────────────────
NETWORK=testnet
PARI_MATCH_FACTORY_ADDRESS=0xbba7f5d1ae23ec476d71d24521a39536b9ec8a2f
STREAM_WALLET_FACTORY_ADDRESS=0xc8647bd4ce332a6a923c66ddd6b5a2f757599399
CHILIZ_SWAP_ROUTER_ADDRESS=0x0c772b744e69bd71b1647b0367a00eb89b0b075d
LEADERBOARD_REWARDS_ADDRESS=0xae845c1035f9abca03f63cc8fdabba94db500981
USDC_ADDRESS=0x66f3ee96a0185216f8cb427d2bc4e53947cef60c
WCHZ_ADDRESS=0x678c34581db0a7808d0ac669d7025f1408c9a3c6

# Indexer confirmation depth (CLAUDE.md §7.7). Must be ≥ 6 on Chiliz to
# survive re-orgs. Override only if you know what you're doing.
INDEXER_REORG_DEPTH=6

# Max blocks per eth_getLogs call during catch-up. Public RPCs cap the range
# (Ankr mainnet rejects >~1000 blocks).
INDEXER_MAX_BLOCK_RANGE=900


# Optional RPC override. Empty = default https://spicy-rpc.chiliz.com.
CHILIZ_RPC_URL=

# Throwaway local key. Generate with `openssl rand -hex 32` and prefix `0x`
# if you need to sign tx in local; never reuse a staging / mainnet key.
ADMIN_PRIVATE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# JWT — generate a local-only secret distinct from staging/prod. Required
# min 32 chars. Suggested: `openssl rand -base64 48`.
# ──────────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_ISSUER=predcast-local
JWT_EXPIRY=24h

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ──────────────────────────────────────────────────────────────────────────
# Rate limit — flip to true to disable every limiter (useful for load tests).
# ──────────────────────────────────────────────────────────────────────────
RATE_LIMIT_DISABLED=false
RATE_LIMIT_WHITELIST=

# ──────────────────────────────────────────────────────────────────────────
# External APIs — optional in local. The backend degrades gracefully when
# absent (price feeds skip, API-Football sync no-ops, CF Stream endpoints
# return 5xx until set).
# ──────────────────────────────────────────────────────────────────────────
API_FOOTBALL_KEY=
# Comma-separated API-Football league IDs to ingest. Default below = full
# Predcast allowlist (~45 IDs). In local dev you usually want a narrower
# scope to spare your API-Football quota — pick a couple of leagues you're
# actively testing (e.g. UCL knockout `2,13` or just `2` for UEFA only).
# Full breakdown of IDs in apps/backend/.env.example.
API_FOOTBALL_LEAGUE_IDS=61,140,39,78,135,88,94,203,71,66,143,45,48,81,137,90,96,97,206,73,526,556,528,529,547,92,550,75,2,3,848,531,4,960,5,1,32,34,31,29,30,33,9,6,13,11,541
PYTH_CHZ_PRICE_FEED_ID=0xe799f456b358a2534aa1b45141d454ac04b444ed23b1440b778549bb758f2b5c
PRICE_FEED_JOB_INTERVAL_MS=300000

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# ──────────────────────────────────────────────────────────────────────────
# Access code gate — leave empty in local to disable. See
# docs/runbook-access-code.md to generate a hash for a custom code.
# Cookie secret: required min 32 chars, generate with `openssl rand -base64 32`.
# ──────────────────────────────────────────────────────────────────────────
ACCESS_CODE_HASH=
ACCESS_CODE_COOKIE_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Metrics endpoint — Bearer token for GET /health/metrics.
# Leave empty in local to keep the endpoint disabled; or generate one with
# `openssl rand -base64 48` to test the auth path.
# ──────────────────────────────────────────────────────────────────────────
METRICS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# HALFTIME market void window — see comment in .env.example. Set to a low
# value (e.g. 60) in local to exercise the void path quickly during smoke
# tests, then reset to the default (900) before pushing.
# ──────────────────────────────────────────────────────────────────────────
HALFTIME_VOID_AFTER_2H_SECONDS=900
