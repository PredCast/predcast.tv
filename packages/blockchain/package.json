{
  "name": "@chiliztv/blockchain",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chains": {
      "types": "./dist/chains/index.d.ts",
      "default": "./dist/chains/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/abis/json && cp src/abis/json/*.json dist/abis/json/",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "^2.31.7"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "typescript": "^5.4.5"
  }
}
